# ─── Generated files (never commit these) ────────────────────────────────────
*.duckdb          # DuckDB database file — regenerated by the pipeline every run
*.duckdb.wal      # DuckDB write-ahead log (temporary, auto-deleted after close)
*.pkl             # Saved ML model files — too large and binary for git

# ─── GCP service account credentials (NEVER commit — treat as a password) ────
*.json            # Covers all service account key files
!pyproject.toml   # (pyproject.toml is TOML not JSON — not affected)

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── MLflow experiment tracking ───────────────────────────────────────────────
# mlruns/ is the local MLflow tracking database.
# Each time you train, MLflow writes metrics and artifacts here.
# It's NOT useful to share in git (highly personal to each machine/run).
mlruns/
mlartifacts/

# ─── Generated report output (binary/HTML) ────────────────────────────────────
# Reports are generated by the pipeline — commit the SCRIPT, not the output.
reports/*.html
reports/*.png
reports/*.pdf

# ─── Python noise ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# ─── uv / pip cache ──────────────────────────────────────────────────────────
# uv.lock is actually USEFUL to commit — it makes the project reproducible.
# But if you want to regenerate it, delete it and run: uv lock
# .uv/
uv.lock

# ─── OS noise ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Editor settings (optional — some teams commit these) ────────────────────
.vscode/settings.json
.idea/
